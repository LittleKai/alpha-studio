{
  "id": "sink-base",
  "version": 1,
  "category": "base-cabinet",
  "tags": [
    "kitchen",
    "sink",
    "base"
  ],
  "description": {
    "vi": "Tu chau rua",
    "en": "Sink base cabinet"
  },
  "params": {
    "width": {
      "type": "number",
      "min": 70,
      "max": 120,
      "default": 90
    },
    "height": {
      "type": "number",
      "min": 80,
      "max": 95,
      "default": 86
    },
    "depth": {
      "type": "number",
      "min": 55,
      "max": 65,
      "default": 60
    }
  },
  "style": {},
  "frontSvg": [
    {
      "type": "rect",
      "x": 0,
      "y": 0,
      "w": "{{width}}",
      "h": "{{height}}",
      "fill": "$cab",
      "stroke": "$cabDark",
      "sw": 1.3
    },
    {
      "type": "rect",
      "x": "{{width / 2 - 18}}",
      "y": 5,
      "w": 36,
      "h": 12,
      "rx": 4,
      "fill": "$glass",
      "stroke": "$glassBorder",
      "sw": 1
    },
    {
      "type": "line",
      "x1": "{{width / 2}}",
      "y1": 20,
      "x2": "{{width / 2}}",
      "y2": "{{height}}",
      "stroke": "$cabEdge",
      "sw": 1
    }
  ],
  "sideSvg": [
    {
      "type": "rect",
      "x": 0,
      "y": 0,
      "w": "{{depth}}",
      "h": "{{height}}",
      "fill": "$cab",
      "stroke": "$cabDark",
      "sw": 1
    }
  ],
  "planSvg": [
    {
      "type": "rect",
      "x": 0,
      "y": 0,
      "w": "{{width}}",
      "h": "{{depth}}",
      "fill": "$cab",
      "stroke": "$cabDark",
      "sw": 1
    },
    {
      "type": "rect",
      "x": "{{width / 2 - 20}}",
      "y": 10,
      "w": 40,
      "h": 28,
      "rx": 5,
      "fill": "$glass",
      "stroke": "$glassBorder",
      "sw": 1
    }
  ],
  "isoBoxes": [
    {
      "x": 0,
      "y": 0,
      "z": 0,
      "w": "{{width}}",
      "h": "{{height}}",
      "d": "{{depth}}",
      "faces": {
        "top": "$woodTop",
        "front": "$woodFront",
        "right": "$woodSide",
        "left": "$woodDark",
        "back": "$woodBack"
      }
    },
    {
      "x": "{{width / 2 - 20}}",
      "y": "{{height}}",
      "z": 10,
      "w": 40,
      "h": 1,
      "d": 28,
      "faces": {
        "top": "$glass",
        "front": "$glassBorder"
      }
    }
  ]
}
